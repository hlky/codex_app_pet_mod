{
  "displayName": "Datachan",
  "description": "A custom Codex pet with configurable animation behavior.",
  "spritesheetPath": "spritesheet.webp",
  "animation": {
    "autoDetectFrames": true,
    "idleSlowdown": 6,
    "states": {
      "idle": {
        "row": 0,
        "durationMs": 140,
        "lastFrameDurationMs": 320
      },
      "jumping": {
        "row": 4,
        "frames": 8,
        "durationMs": 110,
        "lastFrameDurationMs": 240
      },
      "review": {
        "row": 8,
        "durationMs": 150,
        "lastFrameDurationMs": 280
      },
      "waving": {
        "row": 3,
        "durationMs": 140,
        "lastFrameDurationMs": 280
      }
    },
    "chains": {
      "review": ["review", "waving"],
      "jumping": ["jumping", "waving"],
      "running": {
        "mode": "loop",
        "sequence": ["running", "waving", "running-left", "running-right"]
      },
      "waiting": ["waiting", "waving"],
      "failed": ["failed", "waiting"]
    },
    "events": {
      "hover": "waving"
    }
  }
}
